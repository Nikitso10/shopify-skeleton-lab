{% doc %}
  Renders product information including title, vendor, price, and description.
  
  Displays key product details with configurable options for what to show.

  @example
  {% content_for 'block', type: 'product-info', id: 'info' %}
{% enddoc %}

<div class="product-info" {{ block.shopify_attributes }}>
  {% if block.settings.show_vendor and product.vendor != blank %}
    <p class="product-info__vendor">{{ product.vendor }}</p>
  {% endif %}

  {% if block.settings.show_title %}
    <h1 class="product-info__title">{{ product.title }}</h1>
  {% endif %}

  {% if block.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
    <p class="product-info__sku">SKU: {{ product.selected_or_first_available_variant.sku }}</p>
  {% endif %}

  {% if block.settings.show_price %}
    <div class="product-info__price">
      {% if product.compare_at_price > product.price %}
        <span class="product-info__compare-price">
          {{ product.compare_at_price | money }}
        </span>
      {% endif %}
      <span class="product-info__current-price">
        {{ product.price | money }}
      </span>

      {% if product.compare_at_price > product.price %}
        {% assign savings = product.compare_at_price | minus: product.price %}
        {% assign savings_percent = savings | times: 100.0 | divided_by: product.compare_at_price | round %}
        <span class="product-info__savings"> Save {{ savings | money }} ({{ savings_percent }}%) </span>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.show_availability %}
    <div class="product-info__availability">
      {% if product.available %}
        <span class="availability-badge availability-badge--in-stock">
          {{ block.settings.in_stock_text }}
        </span>
      {% else %}
        <span class="availability-badge availability-badge--sold-out">
          {{ block.settings.sold_out_text }}
        </span>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.show_description and product.description != blank %}
    <div class="product-info__description rte">
      {{ product.description }}
    </div>
  {% endif %}

  {% if block.settings.show_tags and product.tags.size > 0 %}
    <div class="product-info__tags">
      {% for tag in product.tags %}
        <span class="product-tag">{{ tag }}</span>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .product-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-info__vendor {
    margin: 0;
    font-size: 0.875rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .product-info__title {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .product-info__sku {
    margin: 0;
    font-size: 0.875rem;
    color: #666;
    font-family: monospace;
  }

  .product-info__price {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .product-info__compare-price {
    font-size: 1.25rem;
    color: #666;
    text-decoration: line-through;
  }

  .product-info__current-price {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-foreground, #000);
  }

  .product-info__compare-price + .product-info__current-price {
    color: #dc2626;
  }

  .product-info__savings {
    font-size: 0.875rem;
    font-weight: 600;
    color: #dc2626;
    background: #fee2e2;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  .product-info__availability {
    display: flex;
    align-items: center;
  }

  .availability-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .availability-badge--in-stock {
    background: #dcfce7;
    color: #166534;
  }

  .availability-badge--sold-out {
    background: #fee2e2;
    color: #991b1b;
  }

  .product-info__description {
    font-size: 1rem;
    line-height: 1.6;
    color: #374151;
  }

  .product-info__description h1,
  .product-info__description h2,
  .product-info__description h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .product-info__description p {
    margin: 0 0 1rem;
  }

  .product-info__description ul,
  .product-info__description ol {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .product-info__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-tag {
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    background: #f3f4f6;
    color: #374151;
    border-radius: 9999px;
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .product-info__title {
      font-size: 1.5rem;
    }

    .product-info__current-price {
      font-size: 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Info",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show product title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show SKU",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_availability",
      "label": "Show availability status",
      "default": true
    },
    {
      "type": "text",
      "id": "in_stock_text",
      "label": "In stock text",
      "default": "In Stock"
    },
    {
      "type": "text",
      "id": "sold_out_text",
      "label": "Sold out text",
      "default": "Sold Out"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show product tags",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Product Info",
      "category": "Product"
    }
  ]
}
{% endschema %}
